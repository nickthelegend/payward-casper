# ---- Casper network ----
CASPER_NETWORK=casper:casper-test
CASPER_CHAIN=casper-test
CASPER_NODE_URL=https://node.testnet.cspr.cloud/rpc

# ---- CSPR.cloud (REST reads + on-chain deploy verification) ----
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_REST=https://api.testnet.cspr.cloud

# ---- x402 facilitator (optional, for pure-x402 settlement mode) ----
X402_FACILITATOR_URL=https://x402-facilitator.cspr.cloud

# ---- gateway resource config (REQUIRED — no defaults faked) ----
# Merchant who receives payment. For the demo you can reuse the deployer account:
#   "00" + deployer account hash
MERCHANT_ACCOUNT_HASH=00db39abe4f2bcc2e69efc834e67f3d4e74c483fd053b560b3466664ae88e10ad4
X402_ASSET_PACKAGE=                     # CEP-18 package hash (64 hex) from deploy-token.mjs
X402_ASSET_NAME=Cep18x402
X402_ASSET_VERSION=1
X402_ASSET_DECIMALS=9
X402_ASSET_SYMBOL=USDC
X402_PRICE_UNITS=1000000                # base units charged per request
FUND402_VAULT_CONTRACT=                 # deployed vault contract hash (64 hex)

# Upstream origin the gateway protects (real data source proxied on success)
ORIGIN_BASE_URL=https://api.coinbase.com/v2

# ---- agent identity (secret in .keys/, gitignored) ----
FUND402_AGENT_PUBLIC_KEY=01bdaee49881c0cfa9fee239ae4833bb2e1bf2d384cc310d50a4c6c431697a9aba
FUND402_AGENT_SECRET_KEY_PATH=.keys/agent_secret.pem
DEPLOYER_PEM=.keys/deployer_secret.pem
LP_PEM=.keys/lp_secret.pem
