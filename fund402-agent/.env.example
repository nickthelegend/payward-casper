# Fund402 agent config. Copy to .env (gitignored) and fill the keys.
CSPR_CLOUD_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Casper (defaults to the live testnet deployment — override if you redeploy)
FUND402_NETWORK=casper:casper-test
FUND402_CHAIN=casper-test
FUND402_NODE_URL=https://node.testnet.casper.network/rpc
CSPR_CLOUD_REST=https://api.testnet.cspr.cloud
FUND402_VAULT_PACKAGE=664d99de146b9b573161a387d89fefc649677351d8a6d2acbe22109bf88f6b12
FUND402_CEP18_PACKAGE=389cedc529cc553e2639884c9dcc5e6dcbeb3920f7f5ca5a39bf7f7b866bccd0
# The funded treasury key (LP + admin + funding source + merchant). Defaults to
# the fund402 deployer key.
FUND402_TREASURY_PEM=../fund402/.keys/deployer_secret.pem
