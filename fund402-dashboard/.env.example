NEXT_PUBLIC_NETWORK=casper-test
# CSPR.cloud REST (server-side reads)
CSPR_CLOUD_API_KEY=
CSPR_CLOUD_REST=https://api.testnet.cspr.cloud
# Vault + asset (set after deploy)
VAULT_ACCOUNT_HASH=
X402_ASSET_PACKAGE=
X402_ASSET_DECIMALS=9

# --- Client-side: CSPR.click wallet writes (deposit / withdraw) ---
# Register your app + get an appId at https://console.cspr.build
NEXT_PUBLIC_CSPR_CLICK_APP_ID=fund402-dashboard
NEXT_PUBLIC_CHAIN_NAME=casper-test
NEXT_PUBLIC_CASPER_NODE_URL=https://node.testnet.cspr.cloud/rpc
# Vault CONTRACT hash (hash-...) — for deposit_liquidity / withdraw_liquidity calls
NEXT_PUBLIC_VAULT_CONTRACT_HASH=
# CEP-18 asset CONTRACT hash (hash-...) — for the approve() before deposit
NEXT_PUBLIC_X402_ASSET_CONTRACT_HASH=
NEXT_PUBLIC_X402_ASSET_DECIMALS=9
